#!/usr/bin/env bash

export GH_PAGER=cat

dir=""
repos_arg=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      printf '\033[1mDescription:\033[0m\n'
      printf '  Scans GitHub repositories and shows a summary of your open PRs\n'
      printf '  awaiting review, PRs others have requested you review, and issues\n'
      printf '  assigned to you — sorted by date and grouped by repo.\n\n'
      printf '\033[1mUsage:\033[0m gh-todo --dir <path> | --repos <repo1,repo2,...>\n\n'
      printf '  Exactly one of --dir or --repos must always be provided.\n\n'
      printf '\033[1mOptions:\033[0m\n'
      printf '  --dir <path>          Discover repos recursively in a directory\n'
      printf '  --repos <r1,r2,...>   Explicit comma-separated list of owner/repo\n'
      printf '  -h, --help            Show this help message\n'
      exit 0
      ;;
    --dir)
      dir="$2"
      shift 2
      ;;
    --repos)
      repos_arg="$2"
      shift 2
      ;;
    *)
      printf '\033[1;91mUnknown argument: %s\033[0m\n' "$1" && exit 1
      ;;
  esac
done

if { [ -n "$repos_arg" ] && [ -n "$dir" ]; } || { [ -z "$repos_arg" ] && [ -z "$dir" ]; }; then
  "$0" --help
  exit 1
fi

if [ -n "$repos_arg" ]; then
  IFS=',' read -ra repos <<< "$repos_arg"
else
  [ ! -d "$dir" ] && printf '\033[1;91mDirectory not found :(\033[0m\n' && exit 1
  repos=()
  while IFS= read -r git_dir; do
    remote=$(git -C "$(dirname "$git_dir")" remote get-url origin 2>/dev/null) || continue
    [[ "$remote" != *github.com* ]] && continue
    repo=$(echo "$remote" | sed 's|.*github\.com[/:]||; s|\.git$||; s|/$||')
    [ -n "$repo" ] && repos+=("$repo")
  done < <(find "$dir" -name ".git" -type d -prune)
  IFS=$'\n' repos=($(printf '%s\n' "${repos[@]}" | sort -u))
  [ ${#repos[@]} -eq 0 ] && printf '\033[1;91mPassed directory has no repositories :(\033[0m\n' && exit 1
fi

valid_repos=()
invalid_repos=()
for repo in "${repos[@]}"; do
  if gh repo view "$repo" --json name &>/dev/null; then
    valid_repos+=("$repo")
  else
    invalid_repos+=("$repo")
  fi
done

if [ ${#valid_repos[@]} -eq 0 ]; then
  printf '\033[1;91mNone of the provided repositories are valid:\033[0m\n'
  for repo in "${invalid_repos[@]}"; do
    printf '\033[1;91m  - %s\033[0m\n' "$repo"
  done
  exit 1
elif [ ${#invalid_repos[@]} -gt 0 ]; then
  printf '\033[1;33mWarning: the following repos are unavailable and will be skipped:\033[0m\n'
  for repo in "${invalid_repos[@]}"; do
    printf '\033[1;33m  - %s\033[0m\n' "$repo"
  done
  echo ""
fi

repos=("${valid_repos[@]}")

me=$(gh api user --jq '.login')

BOLD=$'\033[1m'
RESET=$'\033[0m'
URL=$'\033[90;3m'
YELLOW=$'\033[33m'
GREEN=$'\033[34m'
REPO=$'\033[1;96m'

sort_and_print_prs() {
  jq -rs --arg b "$BOLD" --arg r "$RESET" --arg u "$URL" --arg y "$YELLOW" --arg g "$GREEN" --arg d "$REPO" '
    add // []
    | group_by(.repo)[]
    | (.[0].repo) as $repo
    | "\n\($d)\($repo)\($r)\n\n" + (
        sort_by(.createdAt)
        | map("  \($g)\(.createdAt[:10])\($r)  \($y)#\(.number)\(if .reviewDecision != "" then "  \(.reviewDecision | ascii_downcase | gsub("_";" "))" else "" end)\($r)  \($b)\(.title)\($r)\n  \($u)\(.url)\($r)\n")
        | join("")
      )
  '
}

sort_and_print_prs_with_author() {
  jq -rs --arg b "$BOLD" --arg r "$RESET" --arg u "$URL" --arg y "$YELLOW" --arg g "$GREEN" --arg d "$REPO" '
    add // []
    | group_by(.repo)[]
    | (.[0].repo) as $repo
    | "\n\($d)\($repo)\($r)\n\n" + (
        sort_by(.createdAt)
        | map("  \($g)\(.createdAt[:10])\($r)  \($y)#\(.number)  by \(.author.login)\(if .reviewDecision != "" then "  \(.reviewDecision | ascii_downcase | gsub("_";" "))" else "" end)\($r)  \($b)\(.title)\($r)\n  \($u)\(.url)\($r)\n")
        | join("")
      )
  '
}

sort_and_print_issues() {
  jq -rs --arg b "$BOLD" --arg r "$RESET" --arg u "$URL" --arg y "$YELLOW" --arg g "$GREEN" --arg d "$REPO" '
    add // []
    | group_by(.repo)[]
    | (.[0].repo) as $repo
    | "\n\($d)\($repo)\($r)\n\n" + (
        sort_by(.createdAt)
        | map("  \($g)\(.createdAt[:10])\($r)  \($y)#\(.number)\(if (.labels | length) > 0 then "  \(.labels | map(.name) | join(", "))" else "" end)\($r)  \($b)\(.title)\($r)\n  \($u)\(.url)\($r)\n")
        | join("")
      )
  '
}

section() {
  echo ""
  printf "\033[1;${1}m%s\n%s\033[0m\n" "$2" "$(printf '─%.0s' $(seq 1 ${#2}))"
}

section "91" "Your PRs with no reviewer assigned"
for repo in "${repos[@]}"; do
  gh pr list -R "$repo" --author "$me" \
    --json number,title,url,reviewRequests,reviewDecision,createdAt \
    --jq "[.[] | select(.reviewRequests | length == 0) | . + {repo: \"$repo\"}]"
done | sort_and_print_prs

section "92" "PRs due for your review"
for repo in "${repos[@]}"; do
  gh pr list -R "$repo" --search "review-requested:$me" \
    --json number,title,url,author,reviewDecision,createdAt \
    --jq "[.[] | select(.author.login != \"$me\") | . + {repo: \"$repo\"}]"
done | sort_and_print_prs_with_author

section "95" "Issues assigned to you"
for repo in "${repos[@]}"; do
  gh issue list -R "$repo" --assignee "$me" \
    --json number,title,url,labels,createdAt \
    --jq "[.[] | . + {repo: \"$repo\"}]"
done | sort_and_print_issues

echo ""
